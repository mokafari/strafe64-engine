# build output (rebuildable)
engine/build/
# bundled third-party / generated assets (~1 GB binaries, mp4s, pk3s, model packs — not ours to version)
/assets/
# local map/asset backup tarballs (regenerable snapshots, ~tens of MB)
backups/
# generated courses / tool artifacts (regenerable)
tools/strafegen/generated/
tools/strafegen/generated_fog/
tools/strafegen/__pycache__/
tools/strafegen/shaderlib/__pycache__/
tools/strafegen/sweep_results.jsonl
# downloaded third-party study maps (~166 MB, not ours to version)
tools/strafegen/maps_study/
# built q3map2 binary + generated/asset textures (regenerable)
tools/strafegen/q3map2
tools/strafegen/skytex/
# compiled WASM demo build + bundled assets (rebuildable)
web-demo/
# local Claude Code session config (machine-specific)
.claude/
*.log
.DS_Store
