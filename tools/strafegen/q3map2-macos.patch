 #pragma once
 #include <span>
-
+#include <array>
+#include <cstddef>
+#include <iterator>
+#include <ranges>
+#include <type_traits>
+
+// Upstream defines `template<...> using Span = std::span<...>;` and relies on
+// CTAD for alias templates (C++20 P1814), which Apple clang 15 does not yet
+// implement (landed in clang 19). Define Span as a thin std::span subclass and
+// provide the standard deduction guides on the real class instead, so the 78
+// `Span(ptr, count)` / `Span(range)` call sites deduce exactly as before.
 template<typename _Type, size_t _Extent = std::dynamic_extent>
-using Span = std::span<_Type, _Extent>;
+struct Span : std::span<_Type, _Extent>
+{
+	using std::span<_Type, _Extent>::span;
+	constexpr Span( std::span<_Type, _Extent> s ) noexcept : std::span<_Type, _Extent>( s ) {}
+};
+
+template<class It, class EndOrSize>
+Span( It, EndOrSize ) -> Span<std::remove_reference_t<std::iter_reference_t<It>>>;
+template<class T, size_t N>
+Span( T (&)[N] ) -> Span<T, N>;
+template<class T, size_t N>
+Span( std::array<T, N>& ) -> Span<T, N>;
+template<class T, size_t N>
+Span( const std::array<T, N>& ) -> Span<const T, N>;
+template<class R>
+Span( R&& ) -> Span<std::remove_reference_t<std::ranges::range_reference_t<R>>>;
 
 using StringArrayRange = std::span<const char *const>;
 
